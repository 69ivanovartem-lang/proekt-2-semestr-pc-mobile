<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Статус подключения/операций -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📱 Готов к работе"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <!-- Кнопка сканирования QR -->
        <Button
            android:id="@+id/btnScanQr"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📸 Сканировать QR заказа"
            android:textAllCaps="false"
            android:backgroundTint="#2196F3" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginVertical="16dp"/>

        <!-- Секция создания заказа -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📦 Создать новый заказ"
            android:textSize="14sp"
            android:textColor="#666666"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etPzv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Название ПВЗ"
            android:inputType="text"
            android:text="ПВЗ-Центр" />

        <EditText
            android:id="@+id/etOrderNum"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Номер заказа"
            android:inputType="number"
            android:layout_marginTop="8dp" />

        <EditText
            android:id="@+id/etClient"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Имя клиента"
            android:inputType="textPersonName"
            android:layout_marginTop="8dp" />

        <EditText
            android:id="@+id/etPhone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Телефон клиента"
            android:inputType="phone"
            android:layout_marginTop="8dp" />

        <!-- Кнопка отправки -->
        <Button
            android:id="@+id/btnCreateOrder"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="✅ Отправить заказ"
            android:textAllCaps="false"
            android:backgroundTint="#4CAF50"
            android:layout_marginTop="12dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginVertical="16dp"/>

        <!-- Управление статусами и обновление -->
        <Button
            android:id="@+id/btnChangeStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📝 Изменить статус (после сканирования)"
            android:textAllCaps="false"
            android:backgroundTint="#FF9800" />

        <Button
            android:id="@+id/btnRefresh"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔄 Обновить список с сервера"
            android:textAllCaps="false"
            android:backgroundTint="#607D8B"
            android:layout_marginTop="8dp" />

    </LinearLayout>
</ScrollView>