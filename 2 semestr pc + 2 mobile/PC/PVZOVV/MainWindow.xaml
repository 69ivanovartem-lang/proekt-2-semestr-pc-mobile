<Window x:Class="PVZOVV.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ПВЗ Админ-панель" Height="600" Width="900"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <TabControl>
            <!-- Вкладка ЗАКАЗЫ -->
            <TabItem Header="📋 Заказы">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Button Grid.Row="0" Content="🔄 Обновить" Click="RefreshOrders_Click" 
                            HorizontalAlignment="Left" Padding="10,5" Margin="0,0,0,10"/>

                    <DataGrid Grid.Row="1" x:Name="dgOrders" AutoGenerateColumns="False" 
                              IsReadOnly="False" CanUserAddRows="False"
                              SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="№ Заказа" Binding="{Binding order_number}" Width="100"/>
                            <DataGridTextColumn Header="Клиент" Binding="{Binding client_name}" Width="150"/>
                            <DataGridTextColumn Header="Телефон" Binding="{Binding phone_number}" Width="120"/>
                            <DataGridTemplateColumn Header="Статус" Width="150">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox SelectedValue="{Binding status, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  ItemsSource="{Binding DataContext.ValidStatuses, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Действие" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="💾 Сохранить" Click="SaveStatus_Click" 
                                                Tag="{Binding order_number}" Padding="5,3"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Вкладка ТОВАРЫ -->
            <TabItem Header="🛒 Товары">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Форма добавления -->
                    <StackPanel Grid.Row="0" Orientation="Vertical" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <TextBox x:Name="txtProdName" Width="200" Margin="0,0,5,0" 
                                     Tag="Название товара"/>
                            <TextBox x:Name="txtProdQty" Width="80" Margin="0,0,5,0" 
                                     Tag="Кол-во" Text="1"/>
                            <TextBox x:Name="txtProdPrice" Width="80" Margin="0,0,5,0" 
                                     Tag="Цена" Text="0"/>
                            <Button Content="➕ Добавить" Click="AddProduct_Click" Padding="10,5"/>
                        </StackPanel>
                        <TextBox x:Name="txtProdDesc" Margin="0,0,0,5" 
                                 Tag="Описание (необязательно)"/>
                    </StackPanel>

                    <!-- Таблица товаров -->
                    <DataGrid Grid.Row="1" x:Name="dgProducts" AutoGenerateColumns="False" 
                              IsReadOnly="True" CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding id}" Width="50"/>
                            <DataGridTextColumn Header="Название" Binding="{Binding name}" Width="200"/>
                            <DataGridTextColumn Header="Кол-во" Binding="{Binding quantity}" Width="80"/>
                            <DataGridTextColumn Header="Цена" Binding="{Binding price}" Width="80"/>
                            <DataGridTextColumn Header="Описание" Binding="{Binding description}" Width="*"/>
                            <DataGridTemplateColumn Header="Действие" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="🗑️ Удалить" Click="DeleteProduct_Click" 
                                                Tag="{Binding id}" Padding="5,3" Background="#f44336" Foreground="White"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>