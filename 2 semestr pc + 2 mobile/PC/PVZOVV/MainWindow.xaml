<Window x:Class="PVZOVV.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ПВЗ: Управление заказами" Height="600" Width="1000">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Button Grid.Row="0" Content="🔄 Обновить заказы" Click="LoadData_Click" 
                Width="150" Margin="0,0,0,10"/>

        <DataGrid x:Name="OrdersDataGrid" Grid.Row="1" AutoGenerateColumns="False" 
                  IsReadOnly="True" SelectionMode="Single" 
                  SelectionChanged="OrdersDataGrid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="№ Заказа" Binding="{Binding order_number}" Width="100"/>
                <DataGridTextColumn Header="Клиент" Binding="{Binding client_name}" Width="*"/>
                <DataGridTextColumn Header="Телефон" Binding="{Binding phone_number}" Width="120"/>
                <DataGridTextColumn Header="Товары" Binding="{Binding ItemsSummary}" Width="*"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding status}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="2" Text="📦 Товары в заказе:" FontWeight="Bold" 
                   Margin="0,10,0,5"/>

        <DataGrid x:Name="ItemsDataGrid" Grid.Row="3" AutoGenerateColumns="False" 
                  IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Название" Binding="{Binding name}" Width="*"/>
                <DataGridTextColumn Header="Кол-во" Binding="{Binding quantity}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>