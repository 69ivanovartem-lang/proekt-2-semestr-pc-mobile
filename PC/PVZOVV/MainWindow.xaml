<Window x:Class="PVZOVV.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Пункт выдачи заказов" Height="550" Width="900">

    <!-- Главный контейнер (Grid) должен быть единственным прямым потомком Window -->
    <Grid Margin="10">

        <!-- Разделяем экран на 2 колонки -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ЛЕВАЯ ЧАСТЬ: QR-код и информация -->
        <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="1" Margin="0,0,10,0" Padding="10" CornerRadius="5">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="📱 QR-код заказа" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>

                <!-- Место для картинки QR-кода -->
                <Image x:Name="QRCodeImage" Width="200" Height="200" Stretch="Uniform" Margin="0,0,0,15" 
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>

                <TextBlock Text="Выберите заказ в таблице," TextWrapping="Wrap" TextAlignment="Center" FontSize="12" Foreground="Gray"/>

                <Separator Margin="0,20"/>

                <TextBlock x:Name="StatusText" Text="Статус: Не подключено" FontSize="12" HorizontalAlignment="Center" Margin="0,5"/>
                <TextBlock x:Name="LastUpdateText" FontSize="11" Foreground="Gray" HorizontalAlignment="Center" Margin="0,5"/>
            </StackPanel>
        </Border>

        <!-- ПРАВАЯ ЧАСТЬ: Таблица заказов -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Кнопка обновления -->
            <Button Grid.Row="0" Content="🔄 Обновить список" 
                    Width="150" Height="30" 
                    HorizontalAlignment="Left" 
                    Click="LoadData_Click"
                    Margin="0,0,0,10"/>

            <!-- Таблица -->
            <DataGrid x:Name="OrdersDataGrid" 
                      Grid.Row="1"
                      AutoGenerateColumns="False" 
                      IsReadOnly="True"
                      SelectionMode="Single"
                      SelectionChanged="OrdersDataGrid_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="№ Заказа" Binding="{Binding order_number}" Width="100"/>
                    <DataGridTextColumn Header="Клиент" Binding="{Binding client_name}" Width="*"/>
                    <DataGridTextColumn Header="Телефон" Binding="{Binding phone_number}" Width="120"/>
                    <DataGridTextColumn Header="ПВЗ" Binding="{Binding pzv_number}" Width="100"/>
                    <DataGridTextColumn Header="Статус" Binding="{Binding status}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

    </Grid>
</Window>